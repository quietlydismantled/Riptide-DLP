<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RiptideDlp.ViewModels"
        x:Class="RiptideDlp.Views.PrerequisitesDialog"
        x:DataType="vm:PrerequisitesViewModel"
        Title="Prerequisites — y u need dis"
        Width="640" Height="560"
        MinWidth="500" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushPanel}">

    <DockPanel>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="12,8"
                Background="{DynamicResource BrushPanel}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="BtnRefresh"
                        Content="Re-check"
                        Command="{Binding RefreshAllCommand}"
                        Width="100"/>
                <Button x:Name="BtnClose"
                        Content="Close"
                        Width="90"
                        Background="{DynamicResource BrushAccent}"
                        Foreground="White"
                        IsDefault="True"/>
            </StackPanel>
        </Border>

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Riptide DLP shells out to external tools to do the actual work. Here's what they're for and whether you have them."
                   TextWrapping="Wrap"
                   Margin="16,14,16,4"
                   Foreground="{DynamicResource BrushMutedText}"
                   FontSize="12"/>

        <!-- Cards -->
        <ScrollViewer Padding="12,0,12,8">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PrerequisiteEntryViewModel">
                        <Border Margin="4,8"
                                Padding="14,12"
                                Background="{DynamicResource BrushBg}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto">

                                <!-- Status glyph -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                           Text="{Binding StatusGlyph}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Width="36"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource BrushAccent}"
                                           Margin="0,2,12,0"/>

                                <!-- Name + status text -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource BrushText}"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource BrushMutedText}"/>
                                </StackPanel>

                                <!-- Get it button -->
                                <Button Grid.Row="0" Grid.Column="2"
                                        Content="Get it →"
                                        Command="{Binding OpenLinkCommand}"
                                        Padding="10,4"
                                        VerticalAlignment="Center"/>

                                <!-- Description -->
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                           Text="{Binding WhyYouNeed}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource BrushText}"
                                           FontSize="12"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
