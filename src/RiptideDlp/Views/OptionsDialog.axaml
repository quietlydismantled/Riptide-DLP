<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RiptideDlp.ViewModels"
        x:Class="RiptideDlp.Views.OptionsDialog"
        x:DataType="vm:OptionsViewModel"
        Title="Options"
        Width="540" Height="600"
        MinHeight="400"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushPanel}">

    <DockPanel>
        <!-- Save / Cancel footer -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BrushPanel}"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="BtnSave"
                        Content="Save"
                        Width="90"
                        Background="{DynamicResource BrushAccent}"
                        Foreground="White"
                        IsDefault="True"/>
                <Button x:Name="BtnCancel"
                        Content="Cancel"
                        Width="90"
                        Background="{DynamicResource BrushBg}"
                        Foreground="{DynamicResource BrushText}"
                        IsCancel="True"/>
            </StackPanel>
        </Border>

        <ScrollViewer>
            <Grid ColumnDefinitions="2*,3*" Margin="12"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Grid.Styles>
                    <Style Selector="TextBlock.lbl">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                        <Setter Property="Margin" Value="0,6"/>
                    </Style>
                    <Style Selector="TextBox, NumericUpDown, ComboBox">
                        <Setter Property="Background" Value="{DynamicResource BrushBg}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                        <Setter Property="Margin" Value="0,4"/>
                    </Style>
                    <Style Selector="CheckBox">
                        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                        <Setter Property="Margin" Value="0,4"/>
                    </Style>
                    <Style Selector="TextBlock.hint">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </Grid.Styles>

                <!-- Row 0: Concurrent -->
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="Concurrent downloads:"/>
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               Minimum="1" Maximum="20"
                               Value="{Binding Concurrent}"/>

                <!-- Row 1: Output path -->
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Output directory:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputPath}"/>

                <!-- Row 2: Browse output -->
                <TextBlock Grid.Row="2" Grid.Column="0"/>
                <Button Grid.Row="2" Grid.Column="1"
                        x:Name="BtnBrowseOutput"
                        Content="Browse…"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource BrushBg}"
                        Foreground="{DynamicResource BrushText}"
                        Margin="0,0,0,4"/>

                <!-- Row 3: Format -->
                <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="Format string:"/>
                <ComboBox Grid.Row="3" Grid.Column="1"
                          IsEditable="True"
                          Text="{Binding Format}"
                          ItemsSource="{x:Static vm:OptionsViewModel.FormatOptions}"/>

                <!-- Row 4: Rate limit -->
                <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="Rate limit (e.g. 2M):"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding RateLimit}"/>

                <!-- Row 5: Cookies from browser -->
                <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" Text="Cookies from browser:"/>
                <ComboBox Grid.Row="5" Grid.Column="1"
                          IsEditable="True"
                          Text="{Binding CookiesFrom}"
                          ItemsSource="{x:Static vm:OptionsViewModel.CookieOptions}"/>

                <!-- Row 6: Cookie warn -->
                <TextBlock Grid.Row="6" Grid.Column="0"/>
                <TextBlock Grid.Row="6" Grid.Column="1"
                           Classes="hint"
                           Text="{Binding CookieWarnText}"
                           Foreground="{Binding CookieWarnColor}"/>

                <!-- Row 7: Cookie file -->
                <TextBlock Grid.Row="7" Grid.Column="0" Classes="lbl" Text="Cookie file (.txt):"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CookieFile}"/>

                <!-- Row 8: Browse cookie -->
                <TextBlock Grid.Row="8" Grid.Column="0"/>
                <Button Grid.Row="8" Grid.Column="1"
                        x:Name="BtnBrowseCookie"
                        Content="Browse…"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource BrushBg}"
                        Foreground="{DynamicResource BrushText}"
                        Margin="0,0,0,4"/>

                <!-- Row 9: JS runtime -->
                <TextBlock Grid.Row="9" Grid.Column="0" Classes="lbl" Text="JS runtime (n-challenge):"/>
                <ComboBox Grid.Row="9" Grid.Column="1"
                          SelectedItem="{Binding JsRuntime}"
                          ItemsSource="{x:Static vm:OptionsViewModel.JsRuntimeOptions}"/>

                <!-- Row 10: JS status -->
                <TextBlock Grid.Row="10" Grid.Column="0"/>
                <TextBlock Grid.Row="10" Grid.Column="1"
                           Classes="hint"
                           Text="{Binding JsStatusText}"
                           Foreground="{Binding JsStatusColor}"/>

                <!-- Row 11: Player client -->
                <TextBlock Grid.Row="11" Grid.Column="0" Classes="lbl" Text="YouTube player client:"/>
                <ComboBox Grid.Row="11" Grid.Column="1"
                          SelectedItem="{Binding PlayerClient}"
                          ItemsSource="{x:Static vm:OptionsViewModel.PlayerClientOptions}"/>

                <!-- Row 12: Subtitle lang -->
                <TextBlock Grid.Row="12" Grid.Column="0" Classes="lbl" Text="Subtitle languages:"/>
                <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding SubLang}"/>

                <!-- Row 13: Extra args -->
                <TextBlock Grid.Row="13" Grid.Column="0" Classes="lbl" Text="Extra yt-dlp flags:"/>
                <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding ExtraArgs}"/>

                <!-- Row 14–19: Checkboxes (span both columns) -->
                <CheckBox Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Audio only (extract MP3)"
                          IsChecked="{Binding AudioOnly}"/>
                <CheckBox Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Skip existing files (--no-overwrites)"
                          IsChecked="{Binding NoOverwrites}"/>
                <CheckBox Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Ignore errors and continue"
                          IsChecked="{Binding IgnoreErrors}"/>
                <CheckBox Grid.Row="17" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Embed thumbnail"
                          IsChecked="{Binding EmbedThumbnail}"/>
                <CheckBox Grid.Row="18" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Write subtitles"
                          IsChecked="{Binding WriteSubtitles}"/>
                <CheckBox Grid.Row="19" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="SponsorBlock — remove sponsor segments"
                          IsChecked="{Binding SponsorBlock}"/>

            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
